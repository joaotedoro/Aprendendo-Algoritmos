algoritmo converterespaĂ§osmultiplos
var
    frase, nova: string
	i: inteiro
inicio
	escreva("Digite uma frase: ")
	leia(frase)

	i <- 1
	nova <- ""

	enquanto i <= tamanho(frase) e frase[i] = ' ' faĂ§a
		i <- i + 1
	fimenquanto

	enquanto i + 1 <= tamanho(frase) faĂ§a
		se nĂŁo (frase[i] = ' ' e frase[i + 1] = ' ') entĂŁo
			nova <- nova + frase[i]
		fimse
		i <- i + 1
	fimenquanto

	se frase[tamanho(frase)] <> ' ' entĂŁo
		nova <- nova + frase[tamanho(frase)]
	fimse

	escreva("Frase revisada: ", nova)
fimalgoritmo